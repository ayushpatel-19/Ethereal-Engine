# Core app
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3010,http://127.0.0.1:3010

# Storage
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=ethereal_docs
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=50
TESSERACT_CMD=

# Cache
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# Generation
GENERATION_PROVIDER=auto
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=60
MAX_CONTEXT_TOKENS=4096
GENERATION_TEMPERATURE=0.1
GENERATION_MAX_TOKENS=1024

# Retrieval / embeddings
EMBEDDING_PROVIDER=auto
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
PRELOAD_EMBEDDING_MODEL=false
QUERY_UNDERSTANDING_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# Chunking / retrieval tuning
CHUNK_SIZE=512
CHUNK_OVERLAP=64
SEMANTIC_CHUNK_THRESHOLD=0.85
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7
